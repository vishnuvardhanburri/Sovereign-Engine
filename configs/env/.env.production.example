# Sovereign Engine production environment template.
# Copy to .env on the server, fill real values, then run:
#   pnpm prod:check:real

# Public app URL. Do not use localhost in production.
APP_DOMAIN=orbit.yourcompany.com
APP_PROTOCOL=https
DEFAULT_CLIENT_ID=1
XV_REGION=prod

# Durable state.
DATABASE_URL=postgresql://sovereign_user:REPLACE_STRONG_PASSWORD@postgres:5432/sovereign_engine?sslmode=disable
REDIS_URL=redis://redis:6379
CONTAINER_DATABASE_URL=postgresql://sovereign_user:REPLACE_STRONG_PASSWORD@postgres:5432/sovereign_engine?sslmode=disable
CONTAINER_REDIS_URL=redis://redis:6379

# Required secrets. Generate each with: openssl rand -base64 32
AUTH_SECRET=REPLACE_WITH_BASE64_32_BYTES
CRON_SECRET=REPLACE_WITH_BASE64_32_BYTES
SECURITY_KILL_SWITCH_TOKEN=REPLACE_WITH_BASE64_32_BYTES
SECRET_MASTER_KEY_ID=v1
SECRET_MASTER_KEY=REPLACE_WITH_BASE64_32_BYTES
SECRET_MASTER_KEYS=

# Real sending. Keep MOCK_SMTP=true until DNS, suppression, and test recipients pass.
MOCK_SMTP=true
MOCK_SMTP_FASTLANE=false
SMTP_HOST=smtp.your-esp.com
SMTP_PORT=587
SMTP_USER=REPLACE_SMTP_USER
SMTP_PASS=REPLACE_SMTP_PASSWORD
SMTP_SECURE=false
SMTP_FROM_EMAIL=sender@yourdomain.com
# Optional multi-inbox JSON:
# SMTP_ACCOUNTS=[{"user":"sender1@yourdomain.com","pass":"..."},{"user":"sender2@yourdomain.com","pass":"..."}]

# Validation and compliance.
ZEROBOUNCE_API_KEY=REPLACE_ZEROBOUNCE_KEY
SEND_ALLOW_UNKNOWN_VALIDATION=false
UNSUBSCRIBE_SECRET=REPLACE_WITH_BASE64_32_BYTES

# Optional inbound/reply monitoring.
IMAP_HOST=imap.your-esp.com
IMAP_PORT=993
IMAP_SECURE=true
IMAP_USER=REPLACE_IMAP_USER
IMAP_PASS=REPLACE_IMAP_PASSWORD

# Safe default shaping. Start conservative; the Adaptive Controller ramps healthy lanes.
GLOBAL_SENDS_PER_MINUTE=120
GLOBAL_SHAPER_RATE_PER_SEC=2
GLOBAL_SHAPER_BURST=10
SENDER_WORKER_CONCURRENCY=10
LEGACY_LOOP_BATCH_SIZE=10
WORKER_HEARTBEAT_INTERVAL_MS=15000
WORKER_ROTATION_SEND_LIMIT=5000
WORKER_ROTATION_DRAIN_MS=15000
WORKER_ROTATION_MAX_AGE_MS=86400000

# Security posture. Enable internal TLS when managed services support it.
LOG_FORMAT=json
TLS_MIN_VERSION=TLSv1.3
REQUIRE_INTERNAL_TLS=false

# Reputation-as-a-Service API.
REPUTATION_PUBLIC_API_KEY=
PUBLIC_REPUTATION_FREE_DAILY_LIMIT=10
PUBLIC_REPUTATION_PRO_DAILY_LIMIT=1000
PUBLIC_REPUTATION_ENTERPRISE_DAILY_LIMIT=100000
PUBLIC_REPUTATION_BLACKLIST_CACHE_SEC=21600

# Autoscaling profile.
SENDER_MIN_REPLICAS=2
SENDER_MAX_REPLICAS=24
AUTOSCALE_CPU_HIGH=70
AUTOSCALE_CPU_LOW=25
AUTOSCALE_MEM_HIGH=80
AUTOSCALE_TARGET_WAITING_PER_REPLICA=500
AUTOSCALE_QUEUE_HIGH=1000
AUTOSCALE_QUEUE_LOW=25
AUTOSCALE_SCALE_DOWN_IDLE_WINDOWS=4
AUTOSCALE_DRY_RUN=false

# Optional local-only content AI. Keep disabled unless a local Ollama/Mistral/Llama service is deployed.
CONTENT_MUTATION_ENABLED=false
CONTENT_MUTATION_ENDPOINT=http://ollama:11434/api/generate
CONTENT_MUTATION_MODEL=llama3:8b
CONTENT_MUTATION_POOL_SIZE=500
CONTENT_MUTATION_FILL_PER_LOCK=500
CONTENT_MUTATION_TIMEOUT_MS=12000
CONTENT_MUTATION_POOL_TTL_SEC=86400

# ROI dashboard assumptions.
INVESTOR_LEAD_VALUE_USD=0.50
COST_PER_SEND=0.002
ROI_INBOX_LEAD_VALUE_USD=0.50
ROI_COST_PER_SEND_USD=0.002
ROI_INFRA_DAILY_USD=0
ROI_PROXY_DAILY_USD=0
ROI_DOMAIN_DAILY_USD=0

# Optional log archive ops profile.
LOG_MAX_SIZE=50m
LOG_MAX_FILE=10
LOG_ARCHIVE_S3_URI=
LOG_ARCHIVE_AFTER_DAYS=30
